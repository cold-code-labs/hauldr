# ── Postgres (shared core) ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5433

# ── Control plane → Postgres admin connection ──────────────────────────────
HAULDR_DB_ADMIN_URL=postgres://postgres:postgres@localhost:5433/postgres
HAULDR_CONTROL_DB=hauldr
HAULDR_API_PORT=8787

# Bearer key guarding the /v1 management API (openssl rand -hex 32).
# Empty = open (dev only); never leave empty where the API is reachable.
HAULDR_API_KEY=change-me-openssl-rand-hex-32

# ── Auth — project zero (GoTrue) ───────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
HAULDR_JWT_SECRET=change-me-openssl-rand-hex-32
HAULDR_ZERO_DB=hauldr_zero
HAULDR_GOTRUE_URL=http://localhost:9999
HAULDR_MASTER_EMAIL=admin@example.com
HAULDR_MASTER_PASSWORD=change-me

# ── Supavisor (multi-tenant pooler) ────────────────────────────────────────
#   SECRET_KEY_BASE: openssl rand -base64 48
#   VAULT_ENC_KEY:   exactly 32 characters
#   API_JWT_SECRET:  openssl rand -hex 32
SUPAVISOR_SECRET_KEY_BASE=change-me-openssl-rand-base64-48
SUPAVISOR_VAULT_ENC_KEY=change-me-32-characters-exactly00
SUPAVISOR_API_JWT_SECRET=change-me-openssl-rand-hex-32

# Control plane → pooler. Empty HAULDR_POOLER_API_URL = projects use direct
# connections (no pooler).
HAULDR_POOLER_API_URL=http://localhost:4000
HAULDR_POOLER_HOST=localhost
HAULDR_POOLER_PORT=6543
HAULDR_POOLER_SESSION_PORT=5432

# ── Realtime (shared, multi-tenant) ────────────────────────────────────────
# One Realtime service serves every project (each registered as a tenant). The
# control plane reaches its mgmt API in-network at HAULDR_REALTIME_URL and stores
# each project's public host from HAULDR_REALTIME_DOMAIN_PATTERN (the SDK connects
# there; Realtime resolves the tenant from the host's first label).
#   ENC_KEY:         exactly 16 characters (encrypts tenant secrets at rest)
#   SECRET_KEY_BASE: openssl rand -hex 32   (Phoenix)
# API_JWT_SECRET reuses HAULDR_JWT_SECRET (project-zero admin), so the control
# plane signs tenant-mgmt calls with a key it already has. Empty HAULDR_REALTIME_URL
# disables realtime (projects can't opt in).
HAULDR_REALTIME_URL=http://realtime:4000
HAULDR_REALTIME_DOMAIN_PATTERN=realtime-{project}.example.com
HAULDR_REALTIME_ENC_KEY=change-me-16-char
HAULDR_REALTIME_SECRET_KEY_BASE=change-me-openssl-rand-hex-32
HAULDR_REALTIME_IMAGE=supabase/realtime:v2.102.3

# ── Per-project auth provisioner ───────────────────────────────────────────
# "docker" runs a GoTrue container per project (self-host / dev). Set
# HAULDR_DOCKER_CMD if your user is not in the docker group.
HAULDR_AUTH_PROVISIONER=docker
HAULDR_DOCKER_CMD=docker
HAULDR_GOTRUE_IMAGE=supabase/gotrue:v2.190.0

# "coolify" runs each project's GoTrue as a Coolify docker-image app, routed at
# HAULDR_AUTH_DOMAIN_PATTERN ({project} is substituted). All values come from
# your environment — nothing platform-specific is baked in.
# HAULDR_AUTH_PROVISIONER=coolify
HAULDR_COOLIFY_API_URL=https://coolify.example.com/api/v1
HAULDR_COOLIFY_TOKEN=
HAULDR_COOLIFY_PROJECT_UUID=
HAULDR_COOLIFY_SERVER_UUID=
HAULDR_COOLIFY_DESTINATION_UUID=
HAULDR_AUTH_DOMAIN_PATTERN=auth-{project}.example.com

# Per-project auth endpoints attempt no origin TLS cert when set to "http" — for
# an edge that terminates TLS (e.g. a Cloudflare tunnel), so the origin never
# hangs on ACME for a domain it can't validate directly. Default "https".
# HAULDR_AUTH_SCHEME=https

# ── Per-project auth DNS ───────────────────────────────────────────────────
# Each project's auth host (HAULDR_AUTH_DOMAIN_PATTERN) needs a DNS record
# pointing it at the edge in front of this server. "none" (default) = you manage
# DNS out of band, e.g. a single wildcard record. "cloudflare" = the control
# plane upserts / removes a CNAME per project via the Cloudflare API.
HAULDR_DNS_PROVISIONER=none
# CLOUDFLARE_DNS_TOKEN=     # API token with Zone:DNS:Edit on the zone below
# CLOUDFLARE_ZONE_ID=
# HAULDR_DNS_TARGET=        # what the CNAME points at, e.g. <tunnel-id>.cfargotunnel.com
# HAULDR_DNS_PROXIED=true   # run the record through the CDN/proxy ("orange cloud")
# If CLOUDFLARE_DNS_TOKEN is IP-locked to an IPv4, start the control plane with
# NODE_OPTIONS=--dns-result-order=ipv4first so its API calls don't egress on IPv6.

# ── Fleet jobs (shared pg-boss worker) ─────────────────────────────────────
# A single fleet-wide background-job runner (cron + durable jobs). The control
# plane ensures the worker's login role + dedicated database at bootstrap; the
# `worker` service connects DIRECTLY to Postgres (pg-boss needs session-level
# LISTEN/NOTIFY). Empty password = jobs disabled: the bootstrap step is skipped
# and the worker can't connect.
HAULDR_JOBS_DB=hauldr_jobs
HAULDR_JOBS_ROLE=fleet_worker
HAULDR_JOBS_DB_PASSWORD=

# brokk-access reconciler — grants the review bot (brokk-ccl) push on every repo
# in the org, so a new project needs zero manual steps before brokk opens PRs.
# GH_ADMIN_TOKEN: PAT of an ORG OWNER. Classic: 'repo' scope. Fine-grained: org
# repos, Administration:write + Metadata:read. (NOT the brokk PAT.)
GH_ADMIN_TOKEN=
GH_ORG=cold-code-labs
GH_BOT=brokk-ccl
# Comma-separated repos to SKIP (infra you don't want the bot in), e.g.
# litellm,ratatoskr. Or set GH_BOT_ALLOWLIST to restrict to ONLY listed repos.
GH_BOT_DENYLIST=
# Set to 1 to LOG what would be granted without writing (safe first run / tests).
GH_BOT_DRY_RUN=

# kapso-pull-usage reconciler — pull Kapso workflow token usage into
# kelvin.llm_usage. All three required → the job runs; any unset → it skips.
KAPSO_API_KEY=
KELVIN_SUPABASE_URL=
KELVIN_SUPABASE_SECRET_KEY=
# Optional overrides: workflow id, customer slug, lookback window, schedule.
# KELVIN_WORKFLOW_ID=
# KELVIN_CUSTOMER_SLUG=kelvin
# KAPSO_LOOKBACK_DAYS=7
# KAPSO_CRON=17 3 * * *
# KAPSO_DRY_RUN=
